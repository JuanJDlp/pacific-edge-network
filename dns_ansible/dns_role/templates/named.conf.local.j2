//
// Zona directa para {{ dns_domain }}
//
zone "{{ dns_domain }}" {
    type master;
    file "/etc/bind/zones/db.{{ dns_domain }}";
    allow-transfer { {% for slave in dns_slaves | default([]) %}{{ slave }}; {% endfor %}};
};

//
// Zona inversa para {{ dns_reverse_zone }}
//
zone "{{ dns_reverse_zone }}.in-addr.arpa" {
    type master;
    file "/etc/bind/zones/db.{{ dns_reverse_zone }}";
    allow-transfer { {% for slave in dns_slaves | default([]) %}{{ slave }}; {% endfor %}};
};