# =============================================================================
# /etc/nginx/sites-available/biblioteca
# Managed by Ansible — do not edit manually
# =============================================================================

upstream kiwix_backend {
    server 127.0.0.1:{{ kiwix_port }};
    keepalive 16;
}

upstream kolibri_backend {
    server 127.0.0.1:{{ kolibri_port }};
    keepalive 16;
}

upstream jellyfin_backend {
    server 127.0.0.1:{{ jellyfin_port }};
    keepalive 16;
}

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;

    root /var/www/html;
    index index.html;
    client_max_body_size 200M;

    access_log /var/log/nginx/biblioteca-access.log;
    error_log  /var/log/nginx/biblioteca-error.log warn;

    # ---- Captive-portal probe redirects -----------------------------------
    # OS probes (Android, macOS, Windows, iOS) son redirigidos al portal cautivo
    # del Mini PC en lugar de responder directamente.
    location = /generate_204         { return 302 http://{{ minipc_captive_ip }}:{{ minipc_captive_port }}/; }
    location = /gen_204              { return 302 http://{{ minipc_captive_ip }}:{{ minipc_captive_port }}/; }
    location = /hotspot-detect.html  { return 302 http://{{ minipc_captive_ip }}:{{ minipc_captive_port }}/; }
    location = /library/test/success.html { return 302 http://{{ minipc_captive_ip }}:{{ minipc_captive_port }}/; }
    location = /ncsi.txt             { return 302 http://{{ minipc_captive_ip }}:{{ minipc_captive_port }}/; }
    location = /connecttest.txt      { return 302 http://{{ minipc_captive_ip }}:{{ minipc_captive_port }}/; }
    location = /success.txt          { return 302 http://{{ minipc_captive_ip }}:{{ minipc_captive_port }}/; }
    location = /canonical.html       { return 302 http://{{ minipc_captive_ip }}:{{ minipc_captive_port }}/; }

    # ---- Matrix Discovery & Static ----------------------------------------
    location /.well-known/matrix/client {
        return 200 "{\"m.homeserver\": {\"base_url\": \"https://{{ dns_domain }}:8448\"}}";
        add_header Content-Type application/json;
        add_header Access-Control-Allow-Origin *;
    }
    location /.well-known/matrix/server {
        return 200 "{\"m.server\": \"{{ dns_domain }}:8448\"}";
        add_header Content-Type application/json;
        add_header Access-Control-Allow-Origin *;
    }
    location ^~ /_matrix/static/ {
        root /var/www/html;
        try_files $uri $uri/ =404;
    }

    # ---- Splash + accept (legacy, portal está en Mini PC) -----------------
    location = /splash {
        alias /var/www/html/splash.html;
        default_type text/html;
        add_header Cache-Control "no-store";
    }
    location = /accept {
        return 302 http://192.168.30.1:2050/accept;
    }

    # ---- Static portal ----------------------------------------------------
    # El HTML del panel referencia el ZIM activo por fecha (e.g. wikipedia_es_all_mini_2026-05).
    # Cuando el auto-update de Kiwix cambia esa fecha, el index.html se actualiza, pero Squid
    # (cache en :443) servia la copia vieja por dias -> link muerto para TODOS los clientes.
    # no-cache obliga a Squid/navegador a revalidar el HTML siempre (304 si no cambio).
    location = / {
        add_header Cache-Control "no-cache" always;
        try_files /index.html =404;
    }
    location ~* \.html$ {
        add_header Cache-Control "no-cache" always;
        try_files $uri =404;
    }
    location / {
        try_files $uri $uri/ =404;
    }

    # =====================================================================
    # KIWIX — proxy transparente (sin reescritura de path)
    # =====================================================================

    location /wikipedia/ {
        gzip off;
        rewrite ^/wikipedia/(.*)$ /$1 break;
        proxy_pass http://kiwix_backend;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header Connection        "";
        proxy_set_header Accept-Encoding   "";   # ver kiwix-proxy.conf: evita variante gzip en cache de Squid
        proxy_buffering off;
        proxy_read_timeout 60s;
        error_page 502 504 = @kiwix_unavailable;
    }

    # Contenido ZIM: la URL lleva la version del ZIM (wikipedia_es_all_mini_2026-05/...),
    # asi que es INMUTABLE — si el ZIM cambia, cambia la URL. Cache-Control explicito
    # (no la heuristica de Squid) y se descarta el max-age=3600 conservador de Kiwix.
    location /content/   { proxy_pass http://kiwix_backend; include /etc/nginx/snippets/kiwix-proxy.conf;
                           proxy_hide_header Cache-Control; proxy_hide_header Expires;
                           add_header Cache-Control "public, max-age=31536000, immutable" always; }
    # Catalogo OPDS: metadata pequena y dinamica (cambia al actualizar ZIMs).
    # library.js lo consulta para reescribir los href de las tarjetas; si Squid
    # (cache en :443) sirve una copia rancia o un objeto de 0 bytes, rewriteCards
    # no corre y las tarjetas quedan en su fallback /viewer (incidente 2026-06-03).
    # no-store -> Squid NUNCA lo cachea, siempre lo pide fresco a nginx.
    location /catalog/   { proxy_pass http://kiwix_backend; include /etc/nginx/snippets/kiwix-proxy.conf;
                           proxy_hide_header Cache-Control; add_header Cache-Control "no-store" always; }
    location /viewer     { proxy_pass http://kiwix_backend; include /etc/nginx/snippets/kiwix-proxy.conf; }
    location /skin/      { proxy_pass http://kiwix_backend; include /etc/nginx/snippets/kiwix-proxy.conf;
                           proxy_hide_header Cache-Control; proxy_hide_header Expires;
                           add_header Cache-Control "public, max-age=604800" always; }
    location /search     { proxy_pass http://kiwix_backend; include /etc/nginx/snippets/kiwix-proxy.conf; }
    location /suggest    { proxy_pass http://kiwix_backend; include /etc/nginx/snippets/kiwix-proxy.conf; }
    location /random     { proxy_pass http://kiwix_backend; include /etc/nginx/snippets/kiwix-proxy.conf; }
    location /catch/     { proxy_pass http://kiwix_backend; include /etc/nginx/snippets/kiwix-proxy.conf; }

    location @kiwix_unavailable {
        default_type text/html;
        return 503 '<!doctype html><html lang="es"><meta charset="utf-8">
<title>Wikipedia no disponible</title>
<body style="font-family:sans-serif;max-width:560px;margin:80px auto;padding:0 1rem">
<h1 style="color:#1f6f43">Wikipedia aun no esta lista</h1>
<p>El servicio Kiwix no esta corriendo.</p>
<p><a href="/">&larr; Volver al portal</a></p>
</body></html>';
    }

    # ---- Videos / Jellyfin -------------------------------------------------
    location /videos/ {
        proxy_pass http://jellyfin_backend/;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        $connection_upgrade;
        proxy_buffering off;
        proxy_read_timeout 6h;
        proxy_send_timeout 6h;
    }

    # ---- Health endpoint ---------------------------------------------------
    location = /status {
        alias /var/www/html/status.json;
        default_type application/json;
        add_header Cache-Control "no-store";
    }

    # ---- Wiki del proyecto (single-page en /var/www/html/docs) ------------
    # root ya es /var/www/html, asi que /docs mapea a /var/www/html/docs sin alias.
    location /docs {
        try_files $uri $uri/ /docs/index.html;
        add_header Cache-Control "no-cache" always;
    }

    # ---- Kolibri -----------------------------------------------------------
    location /kolibri/ {
        proxy_pass http://kolibri_backend;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host  $host;
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        $connection_upgrade;
        proxy_buffering    off;
        proxy_read_timeout 600s;
        proxy_buffer_size       16k;
        proxy_buffers           8 16k;
        proxy_busy_buffers_size 32k;
        client_max_body_size    1G;
    }

    # ---- Static portal assets ---------------------------------------------
    location ~ ^/(css|js|images)/.*\.(css|js|png|jpe?g|gif|svg|woff2?)$ {
        expires 7d;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }
}

# =============================================================================
# HTTPS — biblioteca.tel
# Certificado autofirmado generado por el rol nginx (idempotente).
# Mismas locations que el server :80 — el contenido es idéntico por HTTP y HTTPS.
#
# Cuando Squid maneja HTTPS para biblioteca.tel (nginx_serve_https=false), nginx
# NO bindea :443 públicamente — solo escucha en 127.0.0.1:8443 para usos internos.
# Squid (https_port 443 accel) cachea y usa cache_peer 127.0.0.1:80 (HTTP) como backend.
# =============================================================================
server {
{% if nginx_serve_https | default(true) %}
    listen 443 ssl default_server;
    listen [::]:443 ssl default_server;
{% else %}
    listen 127.0.0.1:8443 ssl;
{% endif %}
    server_name _;

    root /var/www/html;
    index index.html;
    client_max_body_size 200M;

    ssl_certificate     /var/www/html/biblioteca-segura.crt;
    ssl_certificate_key /etc/ssl/private/biblioteca.key;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;

    access_log /var/log/nginx/biblioteca-ssl-access.log;
    error_log  /var/log/nginx/biblioteca-ssl-error.log warn;

    # ---- Captive-portal probe redirects -----------------------------------
    location = /generate_204         { return 302 http://{{ minipc_captive_ip }}:{{ minipc_captive_port }}/; }
    location = /gen_204              { return 302 http://{{ minipc_captive_ip }}:{{ minipc_captive_port }}/; }
    location = /hotspot-detect.html  { return 302 http://{{ minipc_captive_ip }}:{{ minipc_captive_port }}/; }
    location = /library/test/success.html { return 302 http://{{ minipc_captive_ip }}:{{ minipc_captive_port }}/; }
    location = /ncsi.txt             { return 302 http://{{ minipc_captive_ip }}:{{ minipc_captive_port }}/; }
    location = /connecttest.txt      { return 302 http://{{ minipc_captive_ip }}:{{ minipc_captive_port }}/; }
    location = /success.txt          { return 302 http://{{ minipc_captive_ip }}:{{ minipc_captive_port }}/; }
    location = /canonical.html       { return 302 http://{{ minipc_captive_ip }}:{{ minipc_captive_port }}/; }

    # ---- Matrix Discovery & Static ----------------------------------------
    location /.well-known/matrix/client {
        return 200 "{\"m.homeserver\": {\"base_url\": \"https://{{ dns_domain }}:8448\"}}";
        add_header Content-Type application/json;
        add_header Access-Control-Allow-Origin *;
    }
    location /.well-known/matrix/server {
        return 200 "{\"m.server\": \"{{ dns_domain }}:8448\"}";
        add_header Content-Type application/json;
        add_header Access-Control-Allow-Origin *;
    }
    location ^~ /_matrix/static/ {
        root /var/www/html;
        try_files $uri $uri/ =404;
    }

    # ---- Static portal ----------------------------------------------------
    # Ver nota en el server :80 — no-cache evita que Squid sirva HTML rancio
    # con links a un ZIM viejo tras un auto-update de Kiwix.
    location = / {
        add_header Cache-Control "no-cache" always;
        try_files /index.html =404;
    }
    location ~* \.html$ {
        add_header Cache-Control "no-cache" always;
        try_files $uri =404;
    }
    location / {
        try_files $uri $uri/ =404;
    }

    # ---- Kiwix / Wikipedia ------------------------------------------------
    location /wikipedia/ {
        gzip off;
        rewrite ^/wikipedia/(.*)$ /$1 break;
        proxy_pass http://kiwix_backend;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header Connection        "";
        proxy_set_header Accept-Encoding   "";   # ver kiwix-proxy.conf: evita variante gzip en cache de Squid
        proxy_buffering off;
        proxy_read_timeout 60s;
        error_page 502 504 = @kiwix_unavailable;
    }

    # Contenido ZIM: la URL lleva la version del ZIM (wikipedia_es_all_mini_2026-05/...),
    # asi que es INMUTABLE — si el ZIM cambia, cambia la URL. Cache-Control explicito
    # (no la heuristica de Squid) y se descarta el max-age=3600 conservador de Kiwix.
    location /content/   { proxy_pass http://kiwix_backend; include /etc/nginx/snippets/kiwix-proxy.conf;
                           proxy_hide_header Cache-Control; proxy_hide_header Expires;
                           add_header Cache-Control "public, max-age=31536000, immutable" always; }
    # Catalogo OPDS: ver nota en el server :80 — no-store para que Squid no
    # envenene la copia que library.js usa para reescribir los href (-> /viewer).
    location /catalog/   { proxy_pass http://kiwix_backend; include /etc/nginx/snippets/kiwix-proxy.conf;
                           proxy_hide_header Cache-Control; add_header Cache-Control "no-store" always; }
    location /viewer     { proxy_pass http://kiwix_backend; include /etc/nginx/snippets/kiwix-proxy.conf; }
    location /skin/      { proxy_pass http://kiwix_backend; include /etc/nginx/snippets/kiwix-proxy.conf;
                           proxy_hide_header Cache-Control; proxy_hide_header Expires;
                           add_header Cache-Control "public, max-age=604800" always; }
    location /search     { proxy_pass http://kiwix_backend; include /etc/nginx/snippets/kiwix-proxy.conf; }
    location /suggest    { proxy_pass http://kiwix_backend; include /etc/nginx/snippets/kiwix-proxy.conf; }
    location /random     { proxy_pass http://kiwix_backend; include /etc/nginx/snippets/kiwix-proxy.conf; }
    location /catch/     { proxy_pass http://kiwix_backend; include /etc/nginx/snippets/kiwix-proxy.conf; }

    location @kiwix_unavailable {
        default_type text/html;
        return 503 '<!doctype html><html lang="es"><meta charset="utf-8">
<title>Wikipedia no disponible</title>
<body style="font-family:sans-serif;max-width:560px;margin:80px auto;padding:0 1rem">
<h1 style="color:#1f6f43">Wikipedia aun no esta lista</h1>
<p>El servicio Kiwix no esta corriendo.</p>
<p><a href="/">&larr; Volver al portal</a></p>
</body></html>';
    }

    # ---- Videos / Jellyfin -------------------------------------------------
    location /videos/ {
        proxy_pass http://jellyfin_backend/;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        $connection_upgrade;
        proxy_buffering off;
        proxy_read_timeout 6h;
        proxy_send_timeout 6h;
    }

    # ---- Health endpoint ---------------------------------------------------
    location = /status {
        alias /var/www/html/status.json;
        default_type application/json;
        add_header Cache-Control "no-store";
    }

    # ---- Wiki del proyecto (single-page en /var/www/html/docs) ------------
    location /docs {
        try_files $uri $uri/ /docs/index.html;
        add_header Cache-Control "no-cache" always;
    }

    # ---- Kolibri -----------------------------------------------------------
    location /kolibri/ {
        proxy_pass http://kolibri_backend;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host  $host;
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        $connection_upgrade;
        proxy_buffering    off;
        proxy_read_timeout 600s;
        proxy_buffer_size       16k;
        proxy_buffers           8 16k;
        proxy_busy_buffers_size 32k;
        client_max_body_size    1G;
    }

    # ---- Static portal assets ---------------------------------------------
    location ~ ^/(css|js|images)/.*\.(css|js|png|jpe?g|gif|svg|woff2?)$ {
        expires 7d;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }
}
