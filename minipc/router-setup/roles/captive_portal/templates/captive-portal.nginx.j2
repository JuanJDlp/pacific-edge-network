# Managed by Ansible — do not edit manually
# Portal cautivo — Splash en http://biblioteca.tel/  (HTTP plano, estilo aeropuerto)
#
# Arquitectura:
#   - Cliente NO autenticado: nftables hace DNAT del HTTP/80 → 192.168.30.1:80
#     (este nginx). El server_name "biblioteca.tel" sirve el splash; cualquier
#     otro Host se redirige a http://biblioteca.tel/ para que la URL bar quede
#     siempre en el dominio canónico.
#   - HTTPS sin auth: nftables sigue DNATeando a :2050 (SSL self-signed). El
#     usuario verá warning de cert; si lo acepta, el splash redirige al dominio HTTP.
#   - Cliente autenticado (mark=0x1): HTTP a destinos != RPi DNAT a :8888 (proxy).
#     HTTP a biblioteca.tel (=RPi) NO se DNATea → llega directo a la RPi.

# ── 1. biblioteca.tel HTTP — splash + /accept ────────────────────────────────
server {
    listen 80;
    listen [::]:80;
    server_name biblioteca.tel;

    root /etc/captive-portal;
    charset utf-8;

    # Descarga del CA Pacific Edge (para clientes que quieran instalar el cert)
    location = /certificado.crt {
        alias /etc/nginx/ssl/captive.crt;
        add_header Content-Disposition 'attachment; filename="PacificEdge_Cert.crt"';
        types { application/x-x509-ca-cert crt; }
    }

    # Aceptar portal — delega al handler Python (necesita root para nft)
    # keepalive_timeout 0 hace que nginx envíe `Connection: close`, forzando al
    # browser a abrir TCP nuevo para el meta-refresh (que entonces evalúa fresh
    # por nftables y obtiene mark=0x1 sin DNAT).
    location = /accept {
        proxy_pass         http://127.0.0.1:{{ captive_accept_port }};
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   Host      $host;
        proxy_read_timeout 5s;
        keepalive_timeout  0;
    }

    # Splash en la raíz
    location = / {
        try_files /splash.html =503;
        add_header Cache-Control "no-cache, no-store, must-revalidate";
        add_header Pragma        no-cache;
    }

    # Cualquier otra path en biblioteca.tel (cuando estoy unauth) → al splash
    location / {
        return 302 http://biblioteca.tel/;
    }
}

# ── 2. Default server HTTP — intercepta probes del SO + cualquier otro Host ──
# Toda request HTTP que NO tenga Host: biblioteca.tel (ej.: tipeaste example.com,
# o el SO probe a captive.apple.com) cae acá. Devolvemos 302 a http://biblioteca.tel/
# para que la barra de URL quede en el dominio canónico Y para que el CNA del SO
# detecte "captive portal" (cualquier respuesta != Success/204 dispara el sheet).
server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;

    root /etc/captive-portal;

    # Probes explícitos (para que el CNA del SO detecte portal y abra el sheet)
    location = /generate_204             { return 302 http://biblioteca.tel/; }
    location = /gen_204                  { return 302 http://biblioteca.tel/; }
    location = /hotspot-detect.html      { return 302 http://biblioteca.tel/; }
    location = /library/test/success.html { return 302 http://biblioteca.tel/; }
    location = /connecttest.txt          { return 302 http://biblioteca.tel/; }
    location = /ncsi.txt                 { return 302 http://biblioteca.tel/; }
    location = /success.txt              { return 302 http://biblioteca.tel/; }
    location = /canonical.html           { return 302 http://biblioteca.tel/; }

    # Cert descargable también acá (por si el browser cae por Host distinto)
    location = /certificado.crt {
        alias /etc/nginx/ssl/captive.crt;
        add_header Content-Disposition 'attachment; filename="PacificEdge_Cert.crt"';
        types { application/x-x509-ca-cert crt; }
    }

    # Catch-all → redirige al portal canónico
    location / {
        return 302 http://biblioteca.tel/;
    }
}

# ── 3. Portal seguro HTTPS — fallback para clientes que llegan vía :443 ─────
# nftables sigue DNATeando HTTPS no-autenticado al :2050 con SSL self-signed.
# Caso de uso: alguien tipea https://lo-que-sea o un sitio HSTS-strict.
# Verán "Tu conexión no es privada" → si proceden, ven el splash. El botón de
# Aceptar usa URL absoluta a http://biblioteca.tel/accept para salir del HTTPS
# autofirmado y aterrizar en el dominio canónico HTTP.
server {
    listen {{ captive_portal_port }} ssl default_server;
    server_name _;

    root /etc/captive-portal;
    charset utf-8;

    ssl_certificate /etc/nginx/ssl/captive.crt;
    ssl_certificate_key /etc/nginx/ssl/captive.key;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    # Si el cliente habla HTTP plano a este puerto SSL → 497, redirige al portal HTTP
    error_page 497 http://biblioteca.tel/;

    location = /certificado.crt {
        alias /etc/nginx/ssl/captive.crt;
        add_header Content-Disposition 'attachment; filename="PacificEdge_Cert.crt"';
        types { application/x-x509-ca-cert crt; }
    }

    location = /accept {
        proxy_pass         http://127.0.0.1:{{ captive_accept_port }};
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   Host      $host;
        proxy_read_timeout 5s;
        keepalive_timeout  0;
    }

    location / {
        try_files /splash.html =503;
        add_header Cache-Control "no-cache, no-store, must-revalidate";
        add_header Pragma        no-cache;
    }
}
