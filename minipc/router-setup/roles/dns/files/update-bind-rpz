#!/usr/bin/env bash
# Managed by Ansible — do not edit manually
# Genera /etc/bind/zones/rpz.blocklist.zone desde listas hosts (StevenBlack).
# RPZ NXDOMAIN para todos los dominios listados.
# Idempotente; designed para cron semanal.

set -euo pipefail

ZONE_FILE="/etc/bind/zones/rpz.blocklist.zone"
DOMAIN="biblioteca.tel"
TMP_DIR="$(mktemp -d)"
trap 'rm -rf "$TMP_DIR"' EXIT

SOURCES=(
  "https://raw.githubusercontent.com/StevenBlack/hosts/master/alternates/porn-only/hosts"
  "https://raw.githubusercontent.com/StevenBlack/hosts/master/alternates/gambling-only/hosts"
)

log() { logger -t bind-rpz "$*"; echo "[$(date -Is)] $*"; }

log "Starting RPZ blocklist update"

i=0
for url in "${SOURCES[@]}"; do
  i=$((i+1))
  if ! curl -fsSL --max-time 60 -o "${TMP_DIR}/src${i}.txt" "$url"; then
    log "ERROR: failed to download ${url} — aborting (keeping previous zone)"
    exit 1
  fi
done

awk '/^0\.0\.0\.0/ {print $2}' "${TMP_DIR}"/src*.txt \
  | grep -Ev '^(0\.0\.0\.0|localhost|broadcasthost|ip6-|biblioteca\.tel)$' \
  | sort -u > "${TMP_DIR}/domains.txt"

COUNT=$(wc -l < "${TMP_DIR}/domains.txt")
if [ "$COUNT" -lt 1000 ]; then
  log "ERROR: only ${COUNT} domains (sanity-check failed) — keeping previous zone"
  exit 1
fi

# Serial epoch-based para que bind detecte cambios.
SERIAL=$(date +%s)

{
  echo "; Generated by update-bind-rpz at $(date -Is)"
  echo "; Source: StevenBlack/hosts (porn-only + gambling-only)"
  echo "; ${COUNT} domains blocked via RPZ NXDOMAIN"
  echo
  echo "\$TTL 60"
  echo "@   IN  SOA ns1.${DOMAIN}. admin.${DOMAIN}. ("
  echo "        ${SERIAL}    ; serial"
  echo "        3600          ; refresh"
  echo "        600           ; retry"
  echo "        86400         ; expire"
  echo "        60            ; minimum TTL"
  echo "    )"
  echo "@   IN  NS  ns1.${DOMAIN}."
  echo
  echo "; Passthru: dominios locales nunca se bloquean"
  echo "${DOMAIN}       CNAME   rpz-passthru."
  echo "*.${DOMAIN}     CNAME   rpz-passthru."
  echo
  echo "; Blocked domains → NXDOMAIN (CNAME a . convencion RPZ)"
  awk '{print $1"\tCNAME\t."; print "*."$1"\tCNAME\t."}' "${TMP_DIR}/domains.txt"
} > "${TMP_DIR}/zone.new"

# Validar con named-checkzone antes de reemplazar.
if ! named-checkzone -q rpz.blocklist "${TMP_DIR}/zone.new"; then
  log "ERROR: named-checkzone fallo — keeping previous zone"
  exit 1
fi

if [ -f "$ZONE_FILE" ] && cmp -s "${TMP_DIR}/zone.new" "$ZONE_FILE"; then
  log "No changes (${COUNT} domains) — skipping reload"
  exit 0
fi

install -m 0644 -o bind -g bind "${TMP_DIR}/zone.new" "$ZONE_FILE"
log "Installed RPZ blocklist with ${COUNT} domains (serial ${SERIAL})"

rndc reload rpz.blocklist >/dev/null 2>&1 || rndc reload >/dev/null 2>&1 || true
log "Bind reload triggered"
