# Managed by Ansible — do not edit manually

options {
    directory "/var/cache/bind";

    # ── Escucha ───────────────────────────────────────────────────────────────
    listen-on {
{% for ip in dns_listen_ips %}
        {{ ip }};
{% endfor %}
    };

    listen-on-v6 {
{% for ip in dns_listen_ips_v6 %}
        {{ ip }};
{% endfor %}
    };

    # ── Queries permitidas ────────────────────────────────────────────────────
    allow-query {
{% for net in dns_allow_query %}
        {{ net }};
{% endfor %}
{% for net in dns_allow_query_v6 %}
        {{ net }};
{% endfor %}
    };

    # ── Recursión permitida solo a redes internas ─────────────────────────────
    allow-recursion {
{% for net in dns_allow_query %}
        {{ net }};
{% endfor %}
{% for net in dns_allow_query_v6 %}
        {{ net }};
{% endfor %}
    };

    # ── Zone transfers: denegar globalmente (solo por llave TSIG en cada zona)
    allow-transfer { none; };

    # ── Forwarders ────────────────────────────────────────────────────────────
    forwarders {
{% for fw in dns_forwarders %}
        {{ fw }};
{% endfor %}
    };
    forward only;

    # ── DNSSEC ────────────────────────────────────────────────────────────────
    dnssec-validation auto;

    # Fix dual-stack: evita timeouts IPv6 que rompen validación DNSSEC
    # BIND en dual-stack intenta resolver DS/DNSKEY por IPv6 y falla.
    filter-aaaa-on-v4 yes;

    # ── DNS64 → NAT64 (Jool) ─────────────────────────────────────────────────
    dns64 {{ dns64_prefix }} {
        clients { any; };
    };
};