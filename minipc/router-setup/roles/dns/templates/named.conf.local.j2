// Managed by Ansible — do not edit manually
// Zonas locales para {{ dns_domain }}

// ── TSIG: llave de autenticación para zone transfers ─────────────────────────
include "/etc/bind/named.conf.tsig";

//
// Zona directa
//
zone "{{ dns_domain }}" {
    type master;
    // Archivo fuente SIN firmar en /var/lib/bind (rw para named bajo AppArmor).
    // Con inline-signing, BIND mantiene ahí la versión firmada
    // (db.{{ dns_domain }}.signed) y el journal (.jnl) automáticamente.
    file "{{ dns_forward_zone_path }}";

    // ── DNSSEC: firmado automático (BIND genera/rota claves y re-firma) ──
    dnssec-policy {{ dnssec_policy }};
    inline-signing yes;
    key-directory "{{ dnssec_key_dir }}";

    // Solo el slave autenticado con TSIG puede hacer AXFR
    // Se elimina la IP explícita — la llave es suficiente y más seguro
    allow-transfer { key "{{ tsig_key_name }}"; };

    // Notificar al slave cuando la zona se re-firme (DNSSEC)
    also-notify {
        {{ dns_slave_ip }};
        {{ dns_slave_ipv6 }};
    };

    notify yes;
};

//
// Zonas inversas por VLAN
//
{% for rz in dns_reverse_zones %}
zone "{{ rz }}.in-addr.arpa" {
    type master;
    file "/etc/bind/zones/db.{{ rz }}";

    allow-transfer { key "{{ tsig_key_name }}"; };

    also-notify {
        {{ dns_slave_ip }};
        {{ dns_slave_ipv6 }};
    };

    notify yes;
};

{% endfor %}

//
// Matrix (Conduit) — zona master local de {{ matrix_domain }}
// El homeserver Matrix vive en la RPi ({{ matrix_host_ip }}); el Mini PC es
// autoritativo de esta zona para que los clientes la resuelvan internamente
// (su :53 va forzado a este master por nftables). Zona aislada: SIN DNSSEC ni
// TSIG, NO se transfiere al slave — no interfiere con {{ dns_domain }}.
//
zone "{{ matrix_domain }}" {
    type master;
    file "{{ matrix_zone_file }}";
    allow-transfer { none; };
};

//
// RPZ offline zone
//
zone "rpz.offline" {
    type master;
    file "/etc/bind/zones/rpz.offline.zone";
    allow-query { none; };
    // RPZ no se transfiere al slave
    allow-transfer { none; };
};

//
// RPZ blocklist zone — porn + gambling (StevenBlack/hosts)
// El archivo lo genera /usr/local/sbin/update-bind-rpz (cron semanal).
// Siempre referenciada por response-policy (ver named.conf.rpz).
//
zone "rpz.blocklist" {
    type master;
    file "/etc/bind/zones/rpz.blocklist.zone";
    allow-query { none; };
    allow-transfer { none; };
};