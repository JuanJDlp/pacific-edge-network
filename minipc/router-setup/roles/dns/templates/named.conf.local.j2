// Managed by Ansible — do not edit manually
// Zonas locales para {{ dns_domain }}

//
// Zona directa
//
zone "{{ dns_domain }}" {
    type master;
    file "/etc/bind/zones/db.{{ dns_domain }}";
    allow-transfer { {{ dns_slave_ip }}; };  // RPi DNS secundario
};

//
// Zonas inversas por VLAN
//
{% for rz in dns_reverse_zones %}
zone "{{ rz }}.in-addr.arpa" {
    type master;
    file "/etc/bind/zones/db.{{ rz }}";
    allow-transfer { {{ dns_slave_ip }}; };  // RPi DNS secundario
};

{% endfor %}

//
// RPZ offline zone — siempre cargada, pero solo activa cuando
// response-policy la referencia (ver named.conf.rpz dentro de options{})
//
zone "rpz.offline" {
    type master;
    file "/etc/bind/zones/rpz.offline.zone";
    allow-query { none; };
};
