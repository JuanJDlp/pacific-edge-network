# Managed by Ansible — do not edit manually
# Chrony — servidor NTP para Pacific Edge Network

# Fuentes NTP upstream (pool colombiano / sudamericano)
pool 0.south-america.pool.ntp.org iburst maxsources 2
pool 1.south-america.pool.ntp.org iburst maxsources 2
pool 2.co.pool.ntp.org iburst maxsources 2

# Servir NTP a las VLANs internas
allow 192.168.0.0/16

# Stratum local cuando no hay conexión WAN
local stratum 10

sourcedir /etc/chrony/sources.d
keyfile /etc/chrony/chrony.keys
driftfile /var/lib/chrony/chrony.drift
ntsdumpdir /var/lib/chrony
logdir /var/log/chrony

maxupdateskew 100.0
rtcsync
makestep 1 3
leapsectz right/UTC
