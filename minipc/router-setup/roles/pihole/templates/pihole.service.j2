# Managed by Ansible — do not edit manually
# Systemd unit para gestionar Pi-hole via Docker Compose

[Unit]
Description=Pi-hole DNS con bloqueo de contenido
Documentation=https://docs.pi-hole.net
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory={{ pihole_data_dir }}
ExecStart=/usr/bin/docker compose up -d --remove-orphans
ExecStop=/usr/bin/docker compose down
ExecReload=/usr/bin/docker compose pull ; /usr/bin/docker compose up -d --remove-orphans
TimeoutStartSec=120
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
