# Managed by Ansible — do not edit manually
global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'minipc_node'
    static_configs:
      - targets: ['localhost:9100']
    relabel_configs:
      - target_label: instance
        replacement: minipc

  - job_name: 'rpi_node'
    static_configs:
      - targets: ['192.168.20.10:9100']
    relabel_configs:
      - target_label: instance
        replacement: rpi-servicios
