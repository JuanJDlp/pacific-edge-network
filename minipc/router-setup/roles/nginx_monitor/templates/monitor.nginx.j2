# Managed by Ansible — do not edit manually
# Reverse proxy: monitor.biblioteca.tel → Grafana + Prometheus

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen {{ monitor_nginx_listen_port }};
    listen [::]:{{ monitor_nginx_listen_port }};
    server_name {{ monitor_nginx_server_name }};

    access_log /var/log/nginx/monitor-access.log;
    error_log  /var/log/nginx/monitor-error.log warn;

    location /prometheus/ {
        proxy_pass http://{{ prometheus_listen_address }}/;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
    }

    location / {
        proxy_pass http://{{ grafana_http_addr }}:{{ grafana_http_port }};
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        $connection_upgrade;
        proxy_read_timeout 300s;
    }
}
