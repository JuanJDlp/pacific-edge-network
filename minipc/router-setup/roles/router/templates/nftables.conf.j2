#!/usr/sbin/nft -f
# Managed by Ansible — do not edit manually

flush ruleset

{% set vlan_ifaces = [] %}
{% for vlan in vlans %}
{% set _ = vlan_ifaces.append(lan_interface ~ '.' ~ vlan.id) %}
{% endfor %}
{% set client_iface = lan_interface ~ '.30' %}
{% set client_vlan_ip = (vlans | selectattr('id', 'equalto', 30) | first).ipv4_address %}

# ─── IPv4/IPv6 filter + captive portal set ───────────────────────────────────

table inet filter {

    # IPs de clientes VLAN30 que aceptaron el portal cautivo (timeout 8h)
    set captive_allowed {
        type ipv4_addr
        flags dynamic, timeout
        timeout 8h
        comment "Clientes VLAN30 autenticados via portal cautivo"
    }

    # Mangle prerouting: marca (0x1) paquetes de clientes ya autenticados.
    # Prioridad mangle (-150) corre ANTES del DNAT (-100) en ip nat.
    chain captive_mangle {
        type filter hook prerouting priority mangle; policy accept;
        iif "{{ client_iface }}" ip saddr @captive_allowed meta mark set 0x1
    }

    chain input {
        type filter hook input priority filter; policy drop;

        iif "lo" accept
        iif "{{ mgmt_interface }}" accept
        ct state established,related accept
        ct state invalid drop
        ip protocol icmp accept
        ip6 nexthdr ipv6-icmp accept

        # SSH, DNS, HTTP, HTTPS desde VLANs LAN
        iif { {{ vlan_ifaces | join(', ') }} } tcp dport { 22, 53, 80, 443 } accept

        # DNS, DHCP, NTP (UDP) desde VLANs LAN
        iif { {{ vlan_ifaces | join(', ') }} } udp dport { 53, 67, 68, 123 } accept

        # Portal cautivo (splash) — solo VLAN30
        iif "{{ client_iface }}" tcp dport {{ captive_portal_port }} accept

        # HTTP proxy intermediario (reenvía a Squid en RPi) — solo VLAN30 autenticada
        iif "{{ client_iface }}" tcp dport {{ http_proxy_port }} accept

        # Monitoreo: Grafana (3000), Prometheus (9090), node_exporter (9100) — solo VLAN10 gestión
        iif "{{ lan_interface }}.10" tcp dport { {{ monitoring_tcp_ports | join(', ') }} } accept
    }

    chain forward {
        type filter hook forward priority filter; policy drop;

        ct state established,related accept
        ct state invalid drop

        # VLAN10 (gestión) y VLAN20 (servidores) → WAN: siempre permitido
        iif { {{ lan_interface }}.10, {{ lan_interface }}.20 } oif "{{ wan_interface }}" accept

        # VLAN30 (clientes) → WAN: solo clientes autenticados en portal
        iif "{{ client_iface }}" oif "{{ wan_interface }}" ip saddr @captive_allowed accept

        # VLAN30 → VLAN20 (servidores, path etiquetado): solo autenticados
        iif "{{ client_iface }}" oif "{{ lan_interface }}.20" ip saddr @captive_allowed accept

        # VLAN30 → servidores (path sin etiqueta, workaround switch): solo autenticados
        iif "{{ client_iface }}" oif "{{ lan_interface }}" ip saddr @captive_allowed accept

        # HTTPS no autenticado: RST inmediato → browser reintenta con HTTP en < 1ms
        iif "{{ client_iface }}" meta mark != 0x1 tcp dport 443 reject with tcp reset
    }

    chain output {
        type filter hook output priority filter; policy accept;
    }
}

# ─── IPv4 NAT ─────────────────────────────────────────────────────────────────

table ip nat {

    chain prerouting {
        type nat hook prerouting priority dstnat; policy accept;

        # DNS de todas las VLANs → Bind9 en Mini PC (VLAN10)
        iif { {{ vlan_ifaces | join(', ') }} } udp dport 53 dnat to {{ dns_redirect_ip }}:53
        iif { {{ vlan_ifaces | join(', ') }} } tcp dport 53 dnat to {{ dns_redirect_ip }}:53

        # Portal cautivo: interceptar HTTP de clientes VLAN30 NO autenticados.
        # mark 0x1 = ya autenticado (captive_mangle corre antes en prioridad mangle).
        iif "{{ client_iface }}" meta mark != 0x1 tcp dport 80 dnat to {{ client_vlan_ip }}:{{ captive_portal_port }}

        # Proxy transparente: HTTP de clientes autenticados (mark 0x1) → nginx intermediario.
        # Se excluye la RPi ({{ rpi_ip }}) para que el acceso directo a biblioteca.local no pase por el proxy.
        # El nginx intermediario reenvía a Squid en RPi (puerto {{ squid_forward_port }}) como forward proxy,
        # evitando el problema de SO_ORIGINAL_DST en DNAT cross-machine.
        iif "{{ client_iface }}" meta mark 0x1 ip daddr != {{ rpi_ip }} tcp dport 80 dnat to {{ client_vlan_ip }}:{{ http_proxy_port }}
    }

    chain postrouting {
        type nat hook postrouting priority srcnat; policy accept;
        oif "{{ wan_interface }}" masquerade
    }
}

# ─── DHCP Broadcast Fix ───────────────────────────────────────────────────────
# macOS en estado APIPA solo acepta DHCP Offers con dst=255.255.255.255.
# Kea usa raw sockets AF_PACKET (bypass netfilter) y envía Offers en unicast.
# La tabla netdev egress opera por debajo de IP y captura estos frames.

table netdev dhcp_fix {
    chain out_vlan30 {
        type filter hook egress device "{{ client_iface }}" priority filter;
        udp sport 67 udp dport 68 ip daddr != 255.255.255.255 \
            ip daddr set 255.255.255.255 ether daddr set ff:ff:ff:ff:ff:ff
    }
}
