{
  "Dhcp4": {

    // ----------------------------------------------------------
    // Interfaz de escucha
    // software de router reenvía los DHCP Discover de VLAN 30 y VLAN 40
    // como unicast hacia este servidor (ip helper-address)
    // ----------------------------------------------------------
    "interfaces-config": {
      "interfaces": [ "{{ kea_listen_interface }}" ]
    },

    // ----------------------------------------------------------
    // Parámetros globales de arrendamiento
    // ----------------------------------------------------------
    "valid-lifetime": {{ kea_valid_lifetime }},
    "renew-timer":    {{ kea_renew_timer }},
    "rebind-timer":   {{ kea_rebind_timer }},

    // ----------------------------------------------------------
    // Base de datos de leases — memfile (CSV persistido en disco)
    // ----------------------------------------------------------
    "lease-database": {
      "type":         "memfile",
      "persist":      true,
      "name":         "{{ kea_leases_file }}",
      "lfc-interval": {{ kea_lfc_interval }}
    },

    // ----------------------------------------------------------
    // Subredes gestionadas
    // ----------------------------------------------------------
    "subnet4": [
{% for subnet in kea_subnets %}
      {
        // {{ subnet.description }}
        "id":     {{ subnet.id }},
        "subnet": "{{ subnet.subnet }}",
        "pools": [
          { "pool": "{{ subnet.pool_start }} - {{ subnet.pool_end }}" }
        ],
        "option-data": [
          {
            "name": "routers",
            "data": "{{ subnet.gateway }}"
          },
          {
            "name": "domain-name-servers",
            "data": "{{ kea_dns_servers }}"
          },
          {
            "name": "domain-search",
            "data": "{{ kea_domain_search }}"
          }
        ]
      }{% if not loop.last %},{% endif %}

{% endfor %}
    ],

    // ----------------------------------------------------------
    // Logging
    // ----------------------------------------------------------
    "loggers": [
      {
        "name": "kea-dhcp4",
        "output_options": [
          {
            "output":   "{{ kea_log_file }}",
            "maxsize":  {{ kea_log_maxsize }},
            "maxver":   {{ kea_log_maxver }}
          }
        ],
        "severity":   "{{ kea_log_severity }}",
        "debuglevel": 0
      }
    ]

  }
}
